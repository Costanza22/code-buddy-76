# Opcional: URL absoluta da API (produção ou preview sem proxy).
# Usa só a ORIGEM (sem /api no fim). Ex.: http://127.0.0.1:3001
# Em desenvolvimento com Vite, deixa vazio e usa o proxy /api -> http://127.0.0.1:3001
# VITE_API_BASE_URL=http://127.0.0.1:3001

# API (opcional)
# PORT=3001
# HOST=localhost
# SESSION_SECRET=uma-string-longa-e-aleatoria-em-producao
